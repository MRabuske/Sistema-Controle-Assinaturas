  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "1.1 Login com credenciais válidas",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@subcontrol.com\",\n  \"password\": \"admin123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Valida status 200",
                  "pm.test('Status code é 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Valida tempo de resposta < 3s",
                  "pm.test('Tempo de resposta menor que 3 segundos', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "// Valida corpo da resposta",
                  "pm.test('Retorna token JWT', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('token');",
                  "    pm.expect(json.token).to.be.a('string');",
                  "    pm.expect(json.token.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Retorna dados do usuário', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.user).to.have.property('id');",
                  "    pm.expect(json.user).to.have.property('name');",
                  "    pm.expect(json.user).to.have.property('email');",
                  "    pm.expect(json.user.email).to.eql('admin@subcontrol.com');",
                  "});",
                  "",
                  "// Salva token para próximas requests",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ]
        },
