    {
      "name": "4. Alertas (HU-003)",
      "item": [
        {
          "name": "4.1 Obter configuração global",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/settings", "host": ["{{baseUrl}}"], "path": ["api", "settings"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code é 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Retorna default_alert_days', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('default_alert_days');",
                  "    pm.expect(json.default_alert_days).to.be.within(1, 30);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.2 Atualizar alerta global (CA2)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/settings/alert", "host": ["{{baseUrl}}"], "path": ["api", "settings", "alert"] },
            "body": { "mode": "raw", "raw": "{\n  \"default_alert_days\": 7\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code é 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Alerta global atualizado para 7 dias', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.default_alert_days).to.eql(7);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.3 Alerta global fora do range (CA3/MSG009)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/settings/alert", "host": ["{{baseUrl}}"], "path": ["api", "settings", "alert"] },
            "body": { "mode": "raw", "raw": "{\n  \"default_alert_days\": 0\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code é 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Retorna MSG009', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.error).to.eql('A antecedência do alerta deve ser um valor entre 1 e 30 dias.');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.4 Configurar alerta individual (CA1)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/subscriptions/1/alert", "host": ["{{baseUrl}}"], "path": ["api", "subscriptions", "1", "alert"] },
            "body": { "mode": "raw", "raw": "{\n  \"alert_days\": 5,\n  \"alert_enabled\": true\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code é 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Alerta individual configurado (CA1)', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.alert_days).to.eql(5);",
                  "    pm.expect(json.alert_enabled).to.eql(1);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.5 Desativar alerta individual (CA6)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/subscriptions/1/alert", "host": ["{{baseUrl}}"], "path": ["api", "subscriptions", "1", "alert"] },
            "body": { "mode": "raw", "raw": "{\n  \"alert_enabled\": false\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code é 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Alerta desativado (CA6)', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.alert_enabled).to.eql(0);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
